<%- include('../partials/header.ejs') %>
<main>
    <h1>My Service Requests</h1>

    <a href="/service-requests/new">New Service Request</a>

    <% if (requests.length === 0) { %>
        <p>You haven't submitted any service requests yet.</p>
    <% } %>

    <% requests.forEach(request => { %>
        <% if (userRole === 'employee' || userRole === 'owner') { %>
            <a href="/employee/service-requests" class="service-request-link">
        <% } %>
        <div class="service-request-row">
            <div class="service-request-info">
                <p><strong><%= request.vehicle_info %></strong> — <%= request.service_type %></p>
                <span class="status-badge status-<%= request.status.toLowerCase().replace(' ', '-') %>"><%= request.status %></span>
                <% if (request.notes) { %>
                    <p class="customer-notes"><%= request.notes %></p>
                <% } %>
                <p><small><%= request.created_at.toLocaleDateString() %></small></p>
            </div>
        </div>
        <% if (userRole === 'employee' || userRole === 'owner') { %>
            </a>
        <% } %>
    <% }) %>
</main>
<%- include('../partials/footer.ejs') %>