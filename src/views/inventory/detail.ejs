<%- include('../partials/header.ejs') %>
<main>
    <h1><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></h1>

    <img src="<%= vehicle.image %>" alt="<%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %>">

    <p>$<%= vehicle.price.toLocaleString() %></p>
    <p><%= vehicle.mileage.toLocaleString() %> miles</p>
    <p><%= vehicle.description %></p>

    <ul>
        <li>Engine: <%= vehicle.specs.engine %></li>
        <li>Transmission: <%= vehicle.specs.transmission %></li>
        <li>Drivetrain: <%= vehicle.specs.drivetrain %></li>
    </ul>

    <h2>Reviews</h2>

    <% if (isLoggedIn) { %>
        <form method="POST" action="/inventory/<%= vehicle.slug %>/reviews">
            <select name="rating" required>
                <option value="5">5 - Excellent</option>
                <option value="4">4 - Good</option>
                <option value="3">3 - Average</option>
                <option value="2">2 - Poor</option>
                <option value="1">1 - Terrible</option>
            </select>
            <textarea name="comment" placeholder="Write a review..."></textarea>
            <button type="submit">Submit Review</button>
        </form>
    <% } else { %>
        <p><a href="/login">Log in</a> to leave a review.</p>
    <% } %>

    <% reviews.forEach(review => { %>
        <div class="review">
            <p><strong><%= review.userName %></strong> - <%= review.rating %>/5</p>
            <p><%= review.comment %></p>

            <% if (currentUserId === review.user_id) { %>
                <a href="/reviews/<%= review.id %>/edit">Edit</a>
                <form method="POST" action="/reviews/<%= review.id %>/delete" style="display:inline;">
                    <button type="submit">Delete</button>
                </form>
            <% } %>
        </div>
    <% }) %>

    <a href="/">Back to Inventory</a>
</main>
<%- include('../partials/footer.ejs') %>