<%- include('../partials/header.ejs') %>
 <main>
    <h1>Welcome to Cars Cars and More Cars!</h1>

    <h2>Inventory</h2>
    <nav class="category-filter">
        <a href="/" class="<%= category === 'All' ? 'active' : '' %>">All</a>
        <a href="/?category=Trucks" class="<%= category === 'Trucks' ? 'active' : '' %>">Trucks</a>
        <a href="/?category=Vans" class="<%= category === 'Vans' ? 'active' : '' %>">Vans</a>
        <a href="/?category=Cars" class="<%= category === 'Cars' ? 'active' : '' %>">Cars</a>
        <a href="/?category=SUVs" class="<%= category === 'SUVs' ? 'active' : '' %>">SUVs</a>
    </nav>
    <div class="vehicle-grid">
        <% vehicles.forEach(vehicle => { %>
          <a href="/inventory/<%= vehicle.slug %>">
            <div class="vehicle-card">
              <img src="<%= vehicle.image %>" alt="<%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %>">
              <h3><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></h3>
              <p>$<%= vehicle.price.toLocaleString() %></p>
            </div>
          </a>
        <% }) %>
    </div>
 </main>
 <%- include('../partials/footer.ejs') %>