<%- include('../partials/header.ejs') %>
<main>
    <h1>Edit <%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></h1>

    <div class="card">
        <form method="POST" action="/employee/vehicles/<%= vehicle.slug %>/edit">
            <label>Price</label>
            <input type="number" name="price" step="0.01" value="<%= vehicle.price %>" required>

            <label>Description</label>
            <textarea name="description"><%= vehicle.description %></textarea>

            <label>
                <input type="checkbox" name="available" <%= vehicle.available ? 'checked' : '' %>>
                Available
            </label>

            <button type="submit">Save</button>
        </form>
    </div>

    <div class="card">
        <h2>Additional Photos</h2>
        <% vehicle.images.forEach(image => { %>
            <div class="gallery-item">
                <img src="<%= image.image_url %>" alt="Vehicle photo" width="150">
                <form method="POST" action="/employee/vehicles/<%= vehicle.slug %>/images/<%= image.id %>/delete" style="display:inline;">
                    <button type="submit">Delete</button>
                </form>
            </div>
        <% }) %>

        <form method="POST" action="/employee/vehicles/<%= vehicle.slug %>/images">
            <input type="text" name="imageUrl" placeholder="Image URL (e.g. /images/inventory/extra1.jpg)" required>
            <button type="submit">Add Photo</button>
        </form>
    </div>
</main>
<%- include('../partials/footer.ejs') %>